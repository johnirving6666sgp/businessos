# Copy to .env and fill in your keys

# Required: at least one LLM key
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BACKUP_API_KEY=

# Required for local dev
SESSION_SECRET=your-secret-key-min-32-chars-change-this

# Local API port (matches wrangler dev port)
API_PORT=8787

# Crawler (optional)
CRAWLER_API_KEY=
CRAWLER_API_URL=http://localhost:8787

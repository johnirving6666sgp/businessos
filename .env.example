# Copy to .env and fill in your keys

# Required: at least one LLM key
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BACKUP_API_KEY=

# Local API port (matches wrangler dev port)
API_PORT=8787

# Crawler (optional) — 服务端与爬虫客户端共用同一个密钥值
CRAWLER_SECRET=
# 爬虫推送目标，本地开发指向本地 API
API_BASE=http://localhost:8787

{
  "name": "business-os",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:ui": "vite --port 5176",
    "dev:api": "node --env-file=.env server.mjs",
    "dev:cf": "wrangler dev --port 8787",
    "build": "vite build",
    "build:cf": "npm run build && wrangler deploy --dry-run",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 execute business-os-db --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute business-os-db --remote --file=migrations/0001_init.sql",
    "db:seed:local": "node scripts/seed-local.mjs",
    "db:seed:demo": "node scripts/seed-demo-data.mjs",
    "db:seed:remote": "node --env-file=.env scripts/seed.mjs --remote",
    "crawler:run": "node --env-file=.env crawler/index.mjs",
    "lint": "eslint src worker"
  },
  "dependencies": {
    "hono": "^4.5.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.12.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "better-sqlite3": "^9.4.0",
    "concurrently": "^8.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.0",
    "wrangler": "^3.80.0"
  }
}
